@page "/movie/{Id:int}"
@inject favapp.Services.ITmdbService TmdbService
@inject favapp.Services.FavoriteService FavoriteService

@* <summary>
    Composant affichant les détails d'un film spécifique en fonction de son identifiant.
    Permet également aux utilisateurs authentifiés d'ajouter ou de retirer ce film 
    de leur liste personnelle de favoris.
    </summary>
*@
<PageTitle>Détails du film</PageTitle>

@if (LeFilm == null)
{
    <p>Recherche des informations du film...</p>
}
else
{
    <div class="row">
        <div class="col-md-4">
            <img src="https://image.tmdb.org/t/p/w500@(LeFilm.PosterPath)" class="img-fluid rounded" />
        </div>
        <div class="col-md-8">
            <h1>@LeFilm.Title</h1>
            <p><strong>Note :</strong> @LeFilm.VoteAverage / 10</p>
            <p><strong>Date de sortie :</strong> @LeFilm.ReleaseDate</p>
        </div>
        <div class="mt-4">
            <AuthorizeView>
                <Authorized>
                    @if (estFavori)
                    {
                        <button class="btn btn-danger" @onclick="ToggleFavori">❤️ Retirer des favoris</button>
                    }
                    else
                    {
                        <button class="btn btn-outline-danger" @onclick="ToggleFavori">🤍 Ajouter aux favoris</button>
                    }
                </Authorized>
                <NotAuthorized>
                    <div class="alert alert-secondary">
                        <a href="/login">Connectez-vous</a> pour ajouter ce film à vos favoris.
                    </div>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </div>
}

@code {
    
    /// <summary>
    /// Paramètre de route contenant l'identifiant unique du film (passé dans l'URL).
    /// </summary>
    [Parameter]
    public int Id { get; set; }

    /// <summary>
    /// L'objet film contenant les informations renvoyées par l'API TMDB.
    /// Vaut 'null' pendant le chargement initial.
    /// </summary>
    private Models.Movie? LeFilm { get; set; }

    /// <summary>
    /// Indique si le film actuellement affiché fait partie des favoris de l'utilisateur connecté.
    /// Détermine le style (plein ou vide) et l'action du bouton de favoris.
    /// </summary>
    private bool estFavori = false;

    /// <summary>
    /// S'exécute à l'ouverture de la page.
    /// Récupère les détails du film via l'API, charge la liste des favoris de l'utilisateur
    /// depuis le LocalStorage, et vérifie si le film actuel y figure pour mettre à jour l'interface.
    /// </summary>
    protected override async Task OnInitializedAsync()
    {
        // 1. On va chercher les infos du film à l'API
        LeFilm = await TmdbService.GetMovieDetailsAsync(Id);

        // 2. On demande au navigateur de charger les favoris depuis le LocalStorage
        await FavoriteService.LoadFavoritesAsync();

        // 3. On regarde si le film actuel est déjà dans le panier
        estFavori = FavoriteService.IsFavorite(Id);
    }

    /// <summary>
    /// Méthode déclenchée par le clic sur le bouton "Ajouter/Retirer des favoris".
    /// Met à jour l'état dans le service (qui sauvegarde automatiquement dans le LocalStorage)
    /// et actualise la variable locale pour changer le style du bouton instantanément.
    /// </summary>
    private async Task ToggleFavori()
    {
        if (estFavori)
        {
            await FavoriteService.RemoveFromFavoritesAsync(Id);
            estFavori = false; // Le cœur devient vide
        }
        else
        {
            await FavoriteService.AddToFavoritesAsync(Id);
            estFavori = true; // Le cœur devient plein
        }
    }
}